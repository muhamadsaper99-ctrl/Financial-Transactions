      {
        "name": "DimTrainFraudLabel",
        "columns": [
          {
            "name": "FraudSK",
            "dataType": "int64",
            "sourceColumn": "FraudSK",
            "sourceProviderType": "Integer"
          },
          {
            "name": "FraudStatus",
            "dataType": "string",
            "sourceColumn": "FraudStatus",
            "sourceProviderType": "WChar"
          }
        ],
        "partitions": [
          {
            "name": "DimTrainFraudLabel",
            "dataView": "full",
            "source": {
              "type": "query",
              "query": " \t\t\t\tSELECT [DWH].[DimTrainFraudLabel].*   FROM [DWH].[DimTrainFraudLabel] ",
              "dataSource": "SqlServer localhost Financial Transactions"
            }
          }
        ],
        "measures": [
          {
            "name": "Fraud Amount $",
            "expression": [
              " ",
              "CALCULATE(",
              "    [Transaction Amount],",
              "    DimTrainFraudLabel[FraudStatus] = \"YES\"",
              ")"
            ]
          },
          {
            "name": "Avg Fraud Amount",
            "expression": [
              " ",
              "CALCULATE(",
              "    AVERAGE(FactTransactions[Amount]),",
              "    DimTrainFraudLabel[FraudStatus] = \"YES\"",
              ")"
            ]
          },
          {
            "name": "Fraud Amount Rate",
            "expression": [
              " ",
              "DIVIDE(",
              "    [Fraud Amount $],",
              "    [Transaction Amount]",
              ")"
            ]
          },
          {
            "name": "Fraud Card Rate",
            "expression": [
              " ",
              "DIVIDE(",
              "    [Fraud Cards],",
              "    [Card]",
              ")"
            ]
          }
        ],
        "annotations": [
          {
            "name": "_TM_ExtProp_QueryDefinition",
            "value": " \t\t\t\tSELECT [DWH].[DimTrainFraudLabel].*   FROM [DWH].[DimTrainFraudLabel] "
          },
